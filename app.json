{
  "expo": {
    "name": "swam",
    "slug": "miniswam",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "miniswam",
    "userInterfaceStyle": "automatic",
    "owner": "pytha",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B6B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pytha.miniswam",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Cette application utilise votre position pour faciliter la livraison de vos commandes.",
        "NSCameraUsageDescription": "Cette application utilise la caméra pour scanner des produits si nécessaire.",
        "NSPhotoLibraryUsageDescription": "Cette application peut accéder à vos photos pour télécharger une image de profil."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FF6B6B"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.pytha.miniswam",
      "versionCode": 2
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "bb7a4fad-9524-4067-bbb9-f7a890ba7bd0"
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF6B6B",
          "sounds": [
            "./assets/notification.wav"
          ]
        }
      ]
    ]
  }
}